---
const categories = [
  { id: 'deportes', label: 'Deportes' },
  { id: 'tv', label: 'TV' },
  { id: 'peliculas', label: 'Películas' },
];

const staticContent: Record<string, { title: string; subtitle: string; tag: string; color: string }[]> = {
  tv: [
    { title: 'El Marginal', subtitle: 'Drama · Temporada 5', tag: 'NUEVO', color: 'linear-gradient(135deg, #0f1a2a 0%, #1e2a3a 50%, #070f1a 100%)' },
    { title: 'Crónica Final', subtitle: 'Thriller · Serie original', tag: 'EXCLUSIVO', color: 'linear-gradient(135deg, #1a0f0f 0%, #2a1e1e 50%, #0f0707 100%)' },
    { title: 'Cocineros Argentinos', subtitle: 'Gastronomía · En vivo', tag: 'EN VIVO', color: 'linear-gradient(135deg, #0f1a0f 0%, #1e2a1e 50%, #070f07 100%)' },
    { title: 'ADN Noticias', subtitle: 'Noticias · 24 horas', tag: 'EN VIVO', color: 'linear-gradient(135deg, #0a0a1a 0%, #1a1a2a 50%, #050509 100%)' },
    { title: 'Pura Química', subtitle: 'Documental · Ciencia', tag: 'NUEVO', color: 'linear-gradient(135deg, #1a1a0a 0%, #2a2a1a 50%, #0f0f05 100%)' },
    { title: 'La Noche de los Campeones', subtitle: 'Entretenimiento', tag: 'ESTRENO', color: 'linear-gradient(135deg, #1a0a1a 0%, #2a1a2a 50%, #0f050f 100%)' },
  ],
  peliculas: [
    { title: 'Corrientes Norte', subtitle: 'Drama · 2h 14m', tag: 'ESTRENO', color: 'linear-gradient(135deg, #0a1a2a 0%, #1a2a3a 50%, #050f1a 100%)' },
    { title: 'El Último Tren', subtitle: 'Acción · 1h 58m', tag: 'NUEVO', color: 'linear-gradient(135deg, #1a0a0a 0%, #2a1a1a 50%, #0f0505 100%)' },
    { title: 'Buenos Aires Noir', subtitle: 'Thriller · 2h 02m', tag: 'POPULAR', color: 'linear-gradient(135deg, #0f0f1a 0%, #1e1e2a 50%, #07070f 100%)' },
    { title: 'La Patagonia Eterna', subtitle: 'Documental · 1h 40m', tag: 'NUEVO', color: 'linear-gradient(135deg, #0a1a0a 0%, #1a2a1a 50%, #050f05 100%)' },
    { title: 'Fuego Cruzado', subtitle: 'Acción · 2h 06m', tag: 'POPULAR', color: 'linear-gradient(135deg, #1a0a0a 0%, #2a1a1a 50%, #0f0505 100%)' },
    { title: 'Tiempo de Lluvia', subtitle: 'Romance · 1h 52m', tag: 'NUEVO', color: 'linear-gradient(135deg, #0a0a1a 0%, #1a1a2a 50%, #05050f 100%)' },
  ],
};

const tagColors: Record<string, string> = {
  'EN VIVO': '#ef4444',
  'HOY': '#f97316',
  'PRÓXIMO': '#6b7280',
  'NUEVO': 'var(--color-accent-light)',
  'EXCLUSIVO': '#8b5cf6',
  'ESTRENO': '#ec4899',
  'POPULAR': '#10b981',
};
---

<section id="ccc-go" style="padding: 5rem 0; background: var(--color-bg); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); overflow: hidden;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">
    <!-- Header -->
    <div style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem;">
      <div>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
          <span style="font-size: 1.5rem; font-weight: 900; color: var(--color-foreground); letter-spacing: -0.04em;">CCC</span>
          <span style="font-size: 1.5rem; font-weight: 900; background: linear-gradient(135deg, var(--color-accent-light), #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -0.04em;">Go</span>
          <span style="font-size: 0.6875rem; font-weight: 700; color: var(--color-accent); background: var(--color-accent-subtle); border: 1px solid var(--color-accent); border-radius: 9999px; padding: 0.2rem 0.6rem; letter-spacing: 0.08em;">STREAMING</span>
        </div>
        <p style="font-size: 0.9375rem; color: var(--color-foreground-alt); margin: 0;">Deportes en vivo, series y películas incluidos en tu plan</p>
      </div>
      <a href="#" style="font-size: 0.875rem; color: var(--color-accent); text-decoration: none; display: flex; align-items: center; gap: 0.4rem; white-space: nowrap;" class="see-all-link">
        Ver todo el catálogo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Category tabs -->
    <div style="display: flex; gap: 0.5rem; margin-bottom: 1.75rem;" class="category-tabs">
      {categories.map((cat, i) => (
        <button
          class={`tab-btn ${i === 0 ? 'active' : ''}`}
          data-category={cat.id}
          style="padding: 0.5rem 1.25rem; border-radius: 9999px; border: 1px solid var(--color-border); background: transparent; color: var(--color-muted); font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: all 0.2s; white-space: nowrap;"
        >
          {cat.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Deportes carousel (populated via API) -->
  <div class="carousel-wrapper" data-carousel="deportes">

    <!-- Desktop slider -->
    <div class="desktop-slider" style="position: relative;">
      <div class="slider-viewport" style="overflow: hidden; position: relative;">
        <div class="slider-track" id="deportes-track" style="display: flex; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
          <!-- Skeleton loading cards -->
          <div class="skeleton-card" style="flex: 0 0 33.333%; padding: 0 0.5rem; box-sizing: border-box;">
            <div class="skeleton-pulse" style="border-radius: 14px; background: var(--color-surface2); aspect-ratio: 16/9; border: 1px solid var(--color-border);"></div>
          </div>
          <div class="skeleton-card" style="flex: 0 0 33.333%; padding: 0 0.5rem; box-sizing: border-box;">
            <div class="skeleton-pulse" style="border-radius: 14px; background: var(--color-surface2); aspect-ratio: 16/9; border: 1px solid var(--color-border);"></div>
          </div>
          <div class="skeleton-card" style="flex: 0 0 33.333%; padding: 0 0.5rem; box-sizing: border-box;">
            <div class="skeleton-pulse" style="border-radius: 14px; background: var(--color-surface2); aspect-ratio: 16/9; border: 1px solid var(--color-border);"></div>
          </div>
        </div>
      </div>

      <button class="slider-arrow arrow-prev" aria-label="Anterior" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 9999px; background: var(--color-overlay); border: 1px solid var(--color-border-light); backdrop-filter: blur(8px); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: background 0.2s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="slider-arrow arrow-next" aria-label="Siguiente" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 9999px; background: var(--color-overlay); border: 1px solid var(--color-border-light); backdrop-filter: blur(8px); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: background 0.2s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>

      <div class="slider-dots" id="deportes-dots" style="display: flex; justify-content: center; gap: 0.4rem; margin-top: 1.25rem; padding: 0 1.5rem;"></div>
    </div>

    <!-- Mobile scroll track -->
    <div class="mobile-track-outer" style="padding: 0 1.5rem;">
      <div class="mobile-track" id="deportes-mobile-track" style="display: flex; gap: 1rem; overflow-x: auto; padding-bottom: 1rem; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
        <!-- Skeleton -->
        <div class="skeleton-pulse" style="flex: 0 0 85vw; max-width: 400px; border-radius: 12px; background: var(--color-surface2); aspect-ratio: 16/9; border: 1px solid var(--color-border);"></div>
        <div class="skeleton-pulse" style="flex: 0 0 85vw; max-width: 400px; border-radius: 12px; background: var(--color-surface2); aspect-ratio: 16/9; border: 1px solid var(--color-border);"></div>
      </div>
    </div>

  </div>

  <!-- Static carousels: TV & Películas -->
  {Object.entries(staticContent).map(([catId, items]) => (
    <div class="carousel-wrapper hidden" data-carousel={catId}>

      <div class="desktop-slider" style="position: relative;">
        <div class="slider-viewport" style="overflow: hidden; position: relative;">
          <div class="slider-track" style="display: flex; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
            {items.map((item) => (
              <div class="slider-card" style={`flex: 0 0 50%; padding: 0 0.5rem; box-sizing: border-box;`}>
                <div style={`border-radius: 14px; background: ${item.color}; border: 1px solid var(--color-pill-bg); overflow: hidden; cursor: pointer; position: relative; aspect-ratio: 16/9; display: flex; flex-direction: column; justify-content: flex-end; padding: 1.5rem 1.75rem;`} class="inner-card">
                  <img src={`https://image.pollinations.ai/prompt/${encodeURIComponent(item.title + ' cinematic cover')}?width=840&height=473&nologo=true`} alt={item.title} style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" class="card-img" loading="lazy" crossorigin="anonymous" />
                  <div style="position: absolute; inset: 0; opacity: 0.04; background-image: url('data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"200\" height=\"200\"><filter id=\"n\"><feTurbulence type=\"fractalNoise\" baseFrequency=\"0.9\" numOctaves=\"4\"/></filter><rect width=\"200\" height=\"200\" filter=\"url(%23n)\" opacity=\"1\"/></svg>'); pointer-events: none; z-index: 1;"></div>
                  <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.1) 100%); pointer-events: none; z-index: 1;"></div>
                  <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 52px; height: 52px; border-radius: 9999px; background: rgba(255,255,255,0.15); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; z-index: 2;" class="play-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M5 3l14 9-14 9V3z"/></svg>
                  </div>
                  <div style={`position: absolute; top: 1rem; left: 1.25rem; font-size: 0.625rem; font-weight: 700; letter-spacing: 0.1em; color: white; background: ${tagColors[item.tag] ?? 'var(--color-accent-light)'}; border-radius: 9999px; padding: 0.25rem 0.6rem; z-index: 2;`}>
                    {item.tag}
                  </div>
                  <div style="position: relative; z-index: 2;">
                    <div style="font-size: 1.125rem; font-weight: 700; color: #ededed; line-height: 1.2; margin-bottom: 0.3rem;">{item.title}</div>
                    <div style="font-size: 0.8125rem; color: rgba(255,255,255,0.7);">{item.subtitle}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <button class="slider-arrow arrow-prev" aria-label="Anterior" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 9999px; background: var(--color-overlay); border: 1px solid var(--color-border-light); backdrop-filter: blur(8px); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: background 0.2s;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="slider-arrow arrow-next" aria-label="Siguiente" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 9999px; background: var(--color-overlay); border: 1px solid var(--color-border-light); backdrop-filter: blur(8px); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; transition: background 0.2s;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>

        <div class="slider-dots" style="display: flex; justify-content: center; gap: 0.4rem; margin-top: 1.25rem; padding: 0 1.5rem;">
          {items.map((_, i) => (
            <button
              class={`dot ${i === 0 ? 'active' : ''}`}
              data-index={i}
              aria-label={`Ir a slide ${i + 1}`}
              style="width: 6px; height: 6px; border-radius: 9999px; border: none; background: var(--color-muted); cursor: pointer; padding: 0; transition: all 0.3s;"
            />
          ))}
        </div>
      </div>

      <div class="mobile-track-outer" style="padding: 0 1.5rem;">
        <div class="mobile-track" style="display: flex; gap: 1rem; overflow-x: auto; padding-bottom: 1rem; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
          {items.map((item) => (
            <div
              class="mobile-card"
              style={`flex: 0 0 200px; border-radius: 12px; background: ${item.color}; border: 1px solid var(--color-pill-bg); overflow: hidden; cursor: pointer; scroll-snap-align: start; position: relative; aspect-ratio: 2/3; display: flex; flex-direction: column; justify-content: flex-end; padding: 1rem;`}
            >
              <img src={`https://image.pollinations.ai/prompt/${encodeURIComponent(item.title + ' cinematic poster')}?width=400&height=600&nologo=true`} alt={item.title} style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" class="card-img" loading="lazy" crossorigin="anonymous" />
              <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.1) 100%); pointer-events: none; z-index: 1;"></div>
              <div style={`position: absolute; top: 0.75rem; left: 0.75rem; font-size: 0.625rem; font-weight: 700; letter-spacing: 0.1em; color: white; background: ${tagColors[item.tag] ?? 'var(--color-accent-light)'}; border-radius: 9999px; padding: 0.2rem 0.5rem; z-index: 2;`}>
                {item.tag}
              </div>
              <div style="position: relative; z-index: 2;">
                <div style="font-size: 0.9375rem; font-weight: 700; color: #ededed; line-height: 1.2; margin-bottom: 0.25rem;">{item.title}</div>
                <div style="font-size: 0.75rem; color: rgba(255,255,255,0.75);">{item.subtitle}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  ))}
</section>

<style>
  .desktop-slider { display: block; }
  .mobile-track-outer { display: none; }

  @media (max-width: 768px) {
    .desktop-slider { display: none; }
    .mobile-track-outer { display: block; }
  }

  .mobile-track::-webkit-scrollbar { height: 3px; }
  .mobile-track::-webkit-scrollbar-track { background: var(--color-surface2); border-radius: 9999px; }
  .mobile-track::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 9999px; }

  .inner-card:hover .play-btn { opacity: 1 !important; }
  .inner-card { transition: box-shadow 0.2s; }
  .inner-card:hover { box-shadow: 0 20px 50px var(--color-card-shadow); }
  .inner-card:hover .card-img { transform: scale(1.03); }

  .mobile-card { transition: transform 0.2s; }
  .mobile-card:hover { transform: translateY(-3px); }
  .mobile-card:hover .card-img { transform: scale(1.03); }

  .tab-btn.active {
    background: rgba(59,130,246,0.12) !important;
    border-color: rgba(59,130,246,0.35) !important;
    color: var(--color-accent) !important;
  }
  .tab-btn:hover:not(.active) {
    border-color: var(--color-border) !important;
    color: var(--color-foreground-alt) !important;
  }
  .hidden { display: none !important; }
  .see-all-link:hover { color: #60a5fa !important; }

  .dot.active { background: var(--color-accent) !important; width: 20px !important; }
  .dot:hover { background: var(--color-foreground-alt) !important; }

  .slider-arrow:hover { background: var(--color-accent) !important; border-color: var(--color-accent) !important; }

  @keyframes skeleton-shimmer {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
  }
  .skeleton-pulse { animation: skeleton-shimmer 1.5s ease-in-out infinite; }

  /* Match card styles */
  .match-inner-card { transition: box-shadow 0.2s; }
  .match-inner-card:hover { box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
  .match-inner-card:hover .card-img { transform: scale(1.03); }
  .match-mobile-card { transition: transform 0.2s; }
  .match-mobile-card:hover { transform: translateY(-3px); }
  .featured-card:hover { box-shadow: 0 0 32px rgba(249,115,22,0.5) !important; }
  .f1-card:hover { box-shadow: 0 0 32px rgba(239,68,68,0.5) !important; }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const wrappers = document.querySelectorAll<HTMLElement>('.carousel-wrapper');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.category;
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      wrappers.forEach((w) => {
        if (w.dataset.carousel === target) {
          w.classList.remove('hidden');
        } else {
          w.classList.add('hidden');
        }
      });
    });
  });

  // Reusable slider initializer
  function initSlider(wrapper: HTMLElement) {
    const track = wrapper.querySelector<HTMLElement>('.slider-track');
    const dotsContainer = wrapper.querySelector<HTMLElement>('.slider-dots');
    const prevBtn = wrapper.querySelector<HTMLButtonElement>('.arrow-prev');
    const nextBtn = wrapper.querySelector<HTMLButtonElement>('.arrow-next');
    const cards = wrapper.querySelectorAll<HTMLElement>('.slider-card');

    if (!track || cards.length === 0) return;

    const total = cards.length;
    const visibleCount = 3;
    const maxIndex = Math.max(0, total - visibleCount);
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function getDots() {
      return dotsContainer ? dotsContainer.querySelectorAll<HTMLButtonElement>('.dot') : [];
    }

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      if (current > maxIndex) current = 0;
      const pct = (100 / visibleCount) * current;
      track!.style.transform = `translateX(-${pct}%)`;
      getDots().forEach((d, i) => d.classList.toggle('active', i === current));
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1 < 0 ? maxIndex : current - 1); }
    function startAuto() { timer = setInterval(next, 3500); }
    function stopAuto() { clearInterval(timer); }

    nextBtn?.addEventListener('click', () => { stopAuto(); next(); startAuto(); });
    prevBtn?.addEventListener('click', () => { stopAuto(); prev(); startAuto(); });

    const viewport = wrapper.querySelector<HTMLElement>('.slider-viewport');
    viewport?.addEventListener('mouseenter', stopAuto);
    viewport?.addEventListener('mouseleave', startAuto);

    // Dots are re-queried on click since they may be dynamic
    dotsContainer?.addEventListener('click', (e) => {
      const dot = (e.target as HTMLElement).closest<HTMLButtonElement>('.dot');
      if (!dot) return;
      const idx = parseInt(dot.dataset.index ?? '0', 10);
      stopAuto();
      goTo(idx);
      startAuto();
    });

    startAuto();
  }

  // Init static carousels (TV, Películas)
  wrappers.forEach((wrapper) => {
    if (wrapper.dataset.carousel !== 'deportes') {
      initSlider(wrapper);
    }
  });

  // TheSportsDB API
  interface SportsEvent {
    idEvent: string;
    idLeague: string;
    strEvent: string;
    strHomeTeam: string;
    strAwayTeam: string;
    strHomeTeamBadge: string;
    strAwayTeamBadge: string;
    strThumb: string;
    strLeague: string;
    strLeagueBadge: string;
    intHomeScore: string | null;
    intAwayScore: string | null;
    strStatus: string;
    strTime: string;
    strTimestamp: string;
    strVenue: string;
    intRound: string;
    dateEvent: string;
  }

  function utcToUTC3(utcTime: string): string {
    const [h, m] = utcTime.split(':').map(Number);
    const hours = ((h - 3) + 24) % 24;
    return `${String(hours).padStart(2, '0')}:${String(m).padStart(2, '0')}`;
  }

  function getMatchTag(event: SportsEvent): { label: string; color: string } {
    const s = event.strStatus;
    if (s === 'Match Finished') return { label: 'FINALIZADO', color: '#6b7280' };
    if (['1H', '2H', 'HT', 'ET', 'PEN', 'Live', 'In Progress'].includes(s)) return { label: 'EN VIVO', color: '#ef4444' };
    const time = event.strTime ? utcToUTC3(event.strTime) : '';
    return { label: time || 'HOY', color: '#f97316' };
  }

  function formatEventDate(dateStr: string): string {
    const months = ['ENE','FEB','MAR','ABR','MAY','JUN','JUL','AGO','SEP','OCT','NOV','DIC'];
    const [, m, d] = dateStr.split('-').map(Number);
    return `${d} ${months[m - 1]}`;
  }

  // Shared footer bar HTML for desktop and mobile
  function footerBar(name: string, time: string, date: string, timeColor: string, mobile = false): string {
    return mobile
      ? `<div style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 2; padding: 0.5rem 0.75rem; display: flex; align-items: center; justify-content: space-between; gap: 0.4rem;">
           <div style="font-size: 0.6875rem; font-weight: 800; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1;">${name}</div>
           <div style="display: flex; align-items: center; gap: 0.4rem; flex-shrink: 0;">
             <span style="font-size: 0.5625rem; font-weight: 700; color: ${timeColor};">${time}</span>
             <span style="font-size: 0.5rem; color: rgba(255,255,255,0.45); white-space: nowrap;">${date}</span>
           </div>
         </div>`
      : `<div style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 2; padding: 0.625rem 1rem; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;">
           <div style="font-size: 0.8125rem; font-weight: 800; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1;">${name}</div>
           <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
             <span style="font-size: 0.6875rem; font-weight: 700; color: ${timeColor};">${time}</span>
             <span style="font-size: 0.5625rem; color: rgba(255,255,255,0.45); white-space: nowrap;">${date}</span>
           </div>
         </div>`;
  }

  function buildFeaturedDesktopCard(event: SportsEvent): string {
    const time = event.strTime?.substring(0, 5) ?? '';
    const date = event.dateEvent ? formatEventDate(event.dateEvent) : '';
    return `
      <div class="slider-card" style="flex: 0 0 33.333%; padding: 0 0.5rem; box-sizing: border-box;">
        <div class="match-inner-card featured-card" style="border-radius: 14px; border: 2px solid #f97316; box-shadow: 0 0 24px rgba(249,115,22,0.3); overflow: hidden; cursor: pointer; position: relative; aspect-ratio: 16/9; width: 100%; background: #1a0a00;">
          <img src="/backgroundTarucas.png" alt="Tarucas" class="card-img" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" />
          <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.97) 100%); pointer-events: none; z-index: 1;"></div>
          <!-- League logo -->
          <div style="position: absolute; top: 0.75rem; right: 0.875rem; z-index: 2;">
            <img src="${event.strLeagueBadge}" alt="${event.strLeague}" width="44" height="44" style="object-fit: contain;" />
          </div>
          <!-- Team badges centred vertically (above footer) -->
          <div style="position: absolute; inset: 0; bottom: 2.5rem; z-index: 2; display: flex; align-items: center; justify-content: space-around; padding: 0 1.5rem;">
            <img src="${event.strHomeTeamBadge}" alt="${event.strHomeTeam}" width="120" height="120" style="object-fit: contain; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.8));" />
            <img src="${event.strAwayTeamBadge}" alt="${event.strAwayTeam}" width="120" height="120" style="object-fit: contain; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.8));" />
          </div>
          ${footerBar(`${event.strEvent} - ESPN 2/ESPN 3`, time, date, '#f97316')}
        </div>
      </div>`;
  }

  function buildFeaturedMobileCard(event: SportsEvent): string {
    const time = event.strTime?.substring(0, 5) ?? '';
    const date = event.dateEvent ? formatEventDate(event.dateEvent) : '';
    return `
      <div class="mobile-card match-mobile-card" style="flex: 0 0 85vw; max-width: 400px; border-radius: 12px; border: 2px solid #f97316; box-shadow: 0 0 20px rgba(249,115,22,0.25); overflow: hidden; cursor: pointer; scroll-snap-align: start; position: relative; aspect-ratio: 16/9; box-sizing: border-box; background: #1a0a00;">
        <img src="/backgroundTarucas.png" alt="Tarucas" class="card-img" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" />
        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.97) 100%); pointer-events: none; z-index: 1;"></div>
        <!-- League logo -->
        <div style="position: absolute; top: 0.6rem; right: 0.75rem; z-index: 2;">
          <img src="${event.strLeagueBadge}" alt="${event.strLeague}" width="36" height="36" style="object-fit: contain;" />
        </div>
        <!-- Team badges -->
        <div style="position: absolute; inset: 0; bottom: 2.25rem; z-index: 2; display: flex; align-items: center; justify-content: space-around; padding: 0 1.25rem;">
          <img src="${event.strHomeTeamBadge}" alt="${event.strHomeTeam}" width="88" height="88" style="object-fit: contain; filter: drop-shadow(0 3px 8px rgba(0,0,0,0.8));" />
          <img src="${event.strAwayTeamBadge}" alt="${event.strAwayTeam}" width="88" height="88" style="object-fit: contain; filter: drop-shadow(0 3px 8px rgba(0,0,0,0.8));" />
        </div>
        ${footerBar(`${event.strEvent} - ESPN 2/ESPN 3`, time, date, '#f97316', true)}
      </div>`;
  }

  function buildF1DesktopCard(event: SportsEvent): string {
    const time = event.strTime ? utcToUTC3(event.strTime) : '';
    const date = event.dateEvent ? formatEventDate(event.dateEvent) : '';
    const thumb = event.strThumb || '';
    return `
      <div class="slider-card" style="flex: 0 0 33.333%; padding: 0 0.5rem; box-sizing: border-box;">
        <div class="match-inner-card featured-card f1-card" style="border-radius: 14px; border: 2px solid #ef4444; box-shadow: 0 0 24px rgba(239,68,68,0.3); overflow: hidden; cursor: pointer; position: relative; aspect-ratio: 16/9; width: 100%; background: #1a0000;">
          ${thumb ? `<img src="${thumb}" alt="${event.strEvent}" class="card-img" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" loading="lazy" />` : ''}
          <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 45%, rgba(0,0,0,0.97) 100%); pointer-events: none; z-index: 1;"></div>
          <div style="position: absolute; top: 0.625rem; right: 0.875rem; z-index: 2;">
            <img src="${event.strLeagueBadge}" alt="${event.strLeague}" width="44" height="44" style="object-fit: contain;" />
          </div>
          ${footerBar(`${event.strEvent} - Fox Sports`, time, date, '#ef4444')}
        </div>
      </div>`;
  }

  function buildF1MobileCard(event: SportsEvent): string {
    const time = event.strTime ? utcToUTC3(event.strTime) : '';
    const date = event.dateEvent ? formatEventDate(event.dateEvent) : '';
    const thumb = event.strThumb || '';
    return `
      <div class="mobile-card match-mobile-card" style="flex: 0 0 85vw; max-width: 400px; border-radius: 12px; border: 2px solid #ef4444; box-shadow: 0 0 20px rgba(239,68,68,0.25); overflow: hidden; cursor: pointer; scroll-snap-align: start; position: relative; aspect-ratio: 16/9; box-sizing: border-box; background: #1a0000;">
        ${thumb ? `<img src="${thumb}" alt="${event.strEvent}" class="card-img" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" loading="lazy" />` : ''}
        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 45%, rgba(0,0,0,0.97) 100%); pointer-events: none; z-index: 1;"></div>
        <div style="position: absolute; top: 0.55rem; right: 0.75rem; z-index: 2;">
          <img src="${event.strLeagueBadge}" alt="${event.strLeague}" width="36" height="36" style="object-fit: contain;" />
        </div>
        ${footerBar(`${event.strEvent} - Fox Sports`, time, date, '#ef4444', true)}
      </div>`;
  }

  function buildDesktopCard(event: SportsEvent): string {
    const tag = getMatchTag(event);
    const date = event.dateEvent ? formatEventDate(event.dateEvent) : '';
    const thumb = event.strThumb || '';
    return `
      <div class="slider-card" style="flex: 0 0 33.333%; padding: 0 0.5rem; box-sizing: border-box;">
        <div class="match-inner-card" style="background: linear-gradient(135deg, #0f2744 0%, #1e3a5f 100%); border-radius: 14px; border: 1px solid var(--color-pill-bg); overflow: hidden; cursor: pointer; position: relative; aspect-ratio: 16/9; width: 100%;">
          ${thumb ? `<img src="${thumb}" alt="${event.strEvent}" class="card-img" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" loading="lazy" />` : ''}
          <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 45%, rgba(0,0,0,0.97) 100%); pointer-events: none; z-index: 1;"></div>
          ${footerBar(event.strEvent, tag.label, date, tag.color)}
        </div>
      </div>`;
  }

  function buildMobileCard(event: SportsEvent): string {
    const tag = getMatchTag(event);
    const date = event.dateEvent ? formatEventDate(event.dateEvent) : '';
    const thumb = event.strThumb || '';
    return `
      <div class="mobile-card match-mobile-card" style="flex: 0 0 85vw; max-width: 400px; border-radius: 12px; background: linear-gradient(135deg, #0f2744 0%, #1e3a5f 100%); border: 1px solid var(--color-pill-bg); overflow: hidden; cursor: pointer; scroll-snap-align: start; position: relative; aspect-ratio: 16/9; box-sizing: border-box;">
        ${thumb ? `<img src="${thumb}" alt="${event.strEvent}" class="card-img" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform 0.5s ease;" loading="lazy" />` : ''}
        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 45%, rgba(0,0,0,0.97) 100%); pointer-events: none; z-index: 1;"></div>
        ${footerBar(event.strEvent, tag.label, date, tag.color, true)}
      </div>`;
  }

  async function loadDeportes() {
    // Compute today and tomorrow in UTC-3
    const nowUTC3 = new Date(Date.now() - 3 * 60 * 60 * 1000);
    const todayUTC3 = nowUTC3.toISOString().split('T')[0];
    const nextDayUTC3Date = new Date(nowUTC3);
    nextDayUTC3Date.setUTCDate(nextDayUTC3Date.getUTCDate() + 1);
    const nextDayUTC3 = nextDayUTC3Date.toISOString().split('T')[0];

    const leagues = [4406, 4328, 4322, 4335, 4331, 4480, 4501];
    const dates = [todayUTC3, nextDayUTC3];
    const urls = leagues.flatMap((l) =>
      dates.map((d) => `https://www.thesportsdb.com/api/v1/json/123/eventsday.php?d=${d}&l=${l}`)
    );

    const deportesWrapper = document.querySelector<HTMLElement>('[data-carousel="deportes"]');
    const track = document.getElementById('deportes-track');
    const mobileTrack = document.getElementById('deportes-mobile-track');
    const dotsContainer = document.getElementById('deportes-dots');

    if (!track || !deportesWrapper) return;

    try {
      // Fetch daily league matches + featured next events in parallel
      const [leagueResults, tarucasData, f1Data] = await Promise.all([
        Promise.allSettled(
          urls.map((u) => fetch(u).then((r) => r.json()).catch(() => null))
        ),
        fetch('https://www.thesportsdb.com/api/v1/json/123/eventsnext.php?id=152109')
          .then((r) => r.json())
          .catch(() => null),
        fetch('https://www.thesportsdb.com/api/v1/json/123/eventsnextleague.php?id=4370')
          .then((r) => r.json())
          .catch(() => null),
      ]);

      const jsons = leagueResults
        .map((r) => (r.status === 'fulfilled' ? r.value : null))
        .filter(Boolean);

      const teamFilters: Record<string, string[]> = {
        '4328': ['Chelsea', 'Arsenal', 'Manchester', 'Liverpool', 'Tottenham', 'Aston'],
        '4335': ['Madrid', 'Barcelona'],
        '4322': ['Milan', 'Inter', 'Roma', 'Atalanta', 'Juventus'],
        '4331': ['Dortmund', 'Bayern'],
      };

      const dailyEvents: SportsEvent[] = jsons
        .flatMap((data) => data.events ?? [])
        .filter((e: SportsEvent) => {
          // Date filter: only today in UTC-3
          const utcMs = new Date(e.strTimestamp + 'Z').getTime();
          const utc3DateStr = new Date(utcMs - 3 * 60 * 60 * 1000).toISOString().split('T')[0];
          if (utc3DateStr !== todayUTC3) return false;
          // Team filter per league
          const allowed = teamFilters[e.idLeague];
          if (!allowed) return true;
          const teams = `${e.strHomeTeam} ${e.strAwayTeam}`;
          return allowed.some((name) => teams.includes(name));
        })
        .sort((a: SportsEvent, b: SportsEvent) => a.strTimestamp.localeCompare(b.strTimestamp));

      const tarucasEvent: SportsEvent | null = tarucasData?.events?.[0] ?? null;
      const f1Event: SportsEvent | null = f1Data?.events?.[0] ?? null;

      track.innerHTML = '';
      if (mobileTrack) mobileTrack.innerHTML = '';
      if (dotsContainer) dotsContainer.innerHTML = '';

      // Build full list: Tarucas featured card first, then daily events
      const allCards: { desktop: string; mobile: string }[] = [];

      if (tarucasEvent) {
        allCards.push({
          desktop: buildFeaturedDesktopCard(tarucasEvent),
          mobile: buildFeaturedMobileCard(tarucasEvent),
        });
      }

      if (f1Event) {
        allCards.push({
          desktop: buildF1DesktopCard(f1Event),
          mobile: buildF1MobileCard(f1Event),
        });
      }

      dailyEvents.forEach((event) => {
        allCards.push({
          desktop: buildDesktopCard(event),
          mobile: buildMobileCard(event),
        });
      });

      if (allCards.length === 0) {
        track.innerHTML = `
          <div style="flex: 0 0 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; aspect-ratio: 16/9; color: var(--color-muted); gap: 0.5rem;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            <span style="font-size: 0.9375rem; font-weight: 500;">No hay partidos hoy</span>
          </div>`;
        return;
      }

      allCards.forEach(({ desktop, mobile }, i) => {
        track.insertAdjacentHTML('beforeend', desktop);
        if (mobileTrack) mobileTrack.insertAdjacentHTML('beforeend', mobile);
        if (dotsContainer) {
          dotsContainer.insertAdjacentHTML('beforeend', `
            <button class="dot${i === 0 ? ' active' : ''}" data-index="${i}" aria-label="Ir a slide ${i + 1}"
              style="width: 6px; height: 6px; border-radius: 9999px; border: none; background: var(--color-muted); cursor: pointer; padding: 0; transition: all 0.3s;"></button>`);
        }
      });

      initSlider(deportesWrapper);
    } catch {
      if (track) {
        track.innerHTML = `
          <div style="flex: 0 0 100%; display: flex; align-items: center; justify-content: center; aspect-ratio: 16/9; color: var(--color-muted); font-size: 0.875rem;">
            Error al cargar los partidos
          </div>`;
      }
    }
  }

  loadDeportes();
</script>
