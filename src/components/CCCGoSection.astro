---
const categories = [
  { id: "deportes", label: "Deportes" },
  { id: "peliculas", label: "On Demand" },
];
---

<!-- Preconnect to image CDNs so the TCP+TLS handshake is done before JS fires -->
<link rel="preconnect" href="https://assets.fanart.tv" crossorigin />
<link rel="preconnect" href="https://m.media-amazon.com" crossorigin />
<link rel="preconnect" href="https://www.thesportsdb.com" crossorigin />

<section
  id="ccc-go"
  style="padding: 5rem 0; background: var(--color-bg); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); overflow: hidden;"
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">
    <!-- Header -->
    <div
      style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem;"
    >
      <div>
        <div
          style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;"
        >
          <span
            style="font-size: 1.5rem; font-weight: 900; color: var(--color-foreground); letter-spacing: -0.04em;"
            >CCC</span
          >
          <span
            style="font-size: 1.5rem; font-weight: 900; background: linear-gradient(135deg, var(--color-accent-light), #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -0.04em;"
            >Go</span
          >
          <span
            style="font-size: 0.6875rem; font-weight: 700; color: var(--color-accent); background: var(--color-accent-subtle); border: 1px solid var(--color-accent); border-radius: 9999px; padding: 0.2rem 0.6rem; letter-spacing: 0.08em;"
            >STREAMING</span
          >
        </div>
        <p
          style="font-size: 0.9375rem; color: var(--color-foreground-alt); margin: 0;"
        >
          Deportes en vivo, series y películas incluidos en tu plan
        </p>
      </div>
      <a
        href="#"
        style="font-size: 0.875rem; color: var(--color-accent); text-decoration: none; display: flex; align-items: center; gap: 0.4rem; white-space: nowrap;"
        class="see-all-link"
      >
        Ver todo el catálogo
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
        >
      </a>
    </div>

    <!-- Category tabs -->
    <div
      style="display: flex; gap: 0.5rem; margin-bottom: 1.75rem;"
      class="category-tabs"
    >
      {
        categories.map((cat, i) => (
          <button
            class={`tab-btn ${i === 0 ? "active" : ""}`}
            data-category={cat.id}
            style="padding: 0.5rem 1.25rem; border-radius: 9999px; border: 1px solid var(--color-border); background: transparent; color: var(--color-muted); font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: all 0.2s; white-space: nowrap;"
          >
            {cat.label}
          </button>
        ))
      }
    </div>
  </div>

  <!-- Deportes carousel (populated via API) -->
  <div class="carousel-wrapper" data-carousel="deportes">
    <!-- Desktop slider -->
    <div class="desktop-slider" style="position: relative;">
      <div
        class="slider-viewport"
        style="overflow: hidden; position: relative;"
      >
        <div
          class="slider-track"
          id="deportes-track"
          style="display: flex; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);"
        >
          <!-- Skeleton loading cards -->
          <div
            class="skeleton-card"
            style="flex: 0 0 33.333%; padding: 0 0.5rem; box-sizing: border-box;"
          >
            <div
              class="skeleton-pulse"
              style="border-radius: 14px; background: var(--color-surface2); aspect-ratio: 16/9; border: 1px solid var(--color-border);"
            >
