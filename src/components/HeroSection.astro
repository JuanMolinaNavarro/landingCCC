---
import Dither from "./Dither.jsx";
---

<section class="hero-section">
    <!-- Dither: large blob in the lower-left, fades into the background via radial mask -->
    <div class="dither-blob" aria-hidden="true">
        <Dither
            client:only="react"
            waveSpeed={0.025}
            waveFrequency={4.2}
            waveAmplitude={0.25}
            waveColor={[0, 0.2706, 0.7137]}
            colorNum={4}
            pixelSize={1}
        />
    </div>

    <!-- Content: two-column grid (text | carousel) -->
    <div class="hero-content">
        <!-- Left column: text -->
        <div class="hero-text">
            <!-- Badge pill -->
            <div class="hero-badge">
                <span class="badge-dot"></span>
                <span>Rápido. Confiable. Conectado.</span>
            </div>

            <!-- Headline -->
            <h1 class="hero-title">
                Conectate al<br />
                <em>futuro.</em>
            </h1>

            <!-- Sub-text -->
            <p class="hero-sub">
                CCC te lleva internet rápido y TV por cable en alta definición a
                tu puerta, todo en un solo plan simple.
            </p>

            <!-- CTA buttons -->
            <div class="hero-ctas">
                <a href="#plans" class="btn-primary">
                    Ver planes
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                    >
                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                    </svg>
                </a>
                <a href="#contact" class="btn-secondary">Contacto</a>
            </div>

            <!-- Trust line -->
            <p class="hero-trust">
                Elegido por más de <span>15.000</span> hogares en toda la provincia.
            </p>
        </div>

        <!-- Right column: promotional carousel -->
        <div class="hero-promo" id="heroPromo">
            <div class="promo-track-wrapper">
                <div class="promo-track" id="promoTrack">
                    <div
                        class="promo-slide promo-slide--1"
                        aria-label="Imagen promocional 1"
                    >
                        <div class="promo-placeholder">
                            <svg
                                width="40"
                                height="40"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                opacity="0.4"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect><circle cx="8.5" cy="8.5" r="1.5"
                                ></circle><path d="m21 15-5-5L5 21"></path>
                            </svg>
                            <span>Imagen promocional 1</span>
                        </div>
                    </div>

                    <div
                        class="promo-slide promo-slide--2"
                        aria-label="Imagen promocional 2"
                    >
                        <div class="promo-placeholder">
                            <svg
                                width="40"
                                height="40"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                opacity="0.4"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect><circle cx="8.5" cy="8.5" r="1.5"
                                ></circle><path d="m21 15-5-5L5 21"></path>
                            </svg>
                            <span>Imagen promocional 2</span>
                        </div>
                    </div>

                    <div
                        class="promo-slide promo-slide--3"
                        aria-label="Imagen promocional 3"
                    >
                        <div class="promo-placeholder">
                            <svg
                                width="40"
                                height="40"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                opacity="0.4"
                            >
                                <rect x="3" y="3" width="18" height="18" rx="2"
                                ></rect><circle cx="8.5" cy="8.5" r="1.5"
                                ></circle><path d="m21 15-5-5L5 21"></path>
                            </svg>
                            <span>Imagen promocional 3</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dot navigation -->
            <div class="promo-dots" id="promoDots">
                <button
                    class="promo-dot active"
                    data-index="0"
                    aria-label="Slide 1"></button>
                <button class="promo-dot" data-index="1" aria-label="Slide 2"
                ></button>
                <button class="promo-dot" data-index="2" aria-label="Slide 3"
                ></button>
            </div>
        </div>
    </div>
</section>

<style>
    /* ── Section ── */
    .hero-section {
        position: relative;
        min-height: 100vh;
        background: var(--color-bg);
        overflow: hidden;
        display: flex;
        align-items: center;
    }

    /* ── Dither blob ── */
    .dither-blob {
        position: absolute;
        left: 0;
        bottom: 0;
        transform: translate(-50%, 50%);
        width: clamp(560px, 70vw, 900px);
        height: clamp(560px, 70vw, 900px);
        overflow: hidden;
        -webkit-mask-image: radial-gradient(
            circle closest-side at 50% 50%,
            black 0%,
            rgba(0, 0, 0, 0.8) 35%,
            rgba(0, 0, 0, 0.3) 65%,
            transparent 90%
        );
        mask-image: radial-gradient(
            circle closest-side at 50% 50%,
            black 0%,
            rgba(0, 0, 0, 0.8) 35%,
            rgba(0, 0, 0, 0.3) 65%,
            transparent 90%
        );
    }
    .dither-blob astro-island {
        display: block;
        width: 100%;
        height: 100%;
    }

    /* ── Content grid ── */
    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 1200px;
        width: 100%;
        margin: 0 auto;
        padding: 8rem 2rem 6rem;
        display: grid;
        grid-template-columns: 55fr 45fr;
        align-items: center;
        gap: 3rem;
    }

    /* ── Left column ── */
    .hero-text {
        display: flex;
        flex-direction: column;
    }

    /* ── Badge ── */
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 0.9rem;
        background: var(--color-pill-bg);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        margin-bottom: 1.75rem;
        font-size: 0.8125rem;
        color: var(--color-muted);
        font-weight: 500;
        letter-spacing: 0.01em;
        align-self: flex-start;
    }
    .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--color-accent);
        flex-shrink: 0;
        box-shadow: 0 0 6px var(--color-accent);
    }

    /* ── Headline ── */
    .hero-title {
        font-size: clamp(2.5rem, 5.5vw, 4.5rem);
        font-weight: 800;
        line-height: 1.06;
        letter-spacing: -0.035em;
        color: var(--color-foreground);
        margin: 0 0 1.25rem;
    }
    .hero-title em {
        font-style: italic;
        color: var(--color-accent);
    }

    /* ── Sub ── */
    .hero-sub {
        font-size: clamp(1rem, 1.8vw, 1.125rem);
        color: var(--color-muted);
        line-height: 1.65;
        max-width: 480px;
        margin: 0 0 2.25rem;
    }

    /* ── CTAs ── */
    .hero-ctas {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
    }
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.4rem;
        background: var(--color-accent);
        color: #fff;
        border-radius: 9999px;
        font-size: 0.9375rem;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid var(--color-accent);
        transition:
            background 0.2s,
            transform 0.15s;
        box-shadow: 0 0 20px var(--color-accent-subtle);
    }
    .btn-primary:hover {
        background: var(--color-accent-light);
        transform: translateY(-1px);
    }
    .btn-secondary {
        display: inline-flex;
        align-items: center;
        padding: 0.7rem 1.4rem;
        background: transparent;
        color: var(--color-foreground);
        border-radius: 9999px;
        font-size: 0.9375rem;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--color-border);
        transition:
            border-color 0.2s,
            color 0.2s,
            transform 0.15s;
    }
    .btn-secondary:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        transform: translateY(-1px);
    }

    /* ── Trust line ── */
    .hero-trust {
        font-size: 0.8125rem;
        color: var(--color-foreground-alt);
        margin: 0;
    }
    .hero-trust span {
        color: var(--color-muted);
    }

    /* ── Right column: promo carousel ── */
    .hero-promo {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .promo-track-wrapper {
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid var(--color-border);
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.25);
    }

    .promo-track {
        display: flex;
        transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        will-change: transform;
    }

    .promo-slide {
        min-width: 100%;
        aspect-ratio: 16 / 9;
        flex-shrink: 0;
        overflow: hidden;
        position: relative;
    }

    /* Placeholder gradients (swap for <img> when real assets are ready) */
    .promo-slide--1 {
        background: linear-gradient(
            135deg,
            #001a4d 0%,
            #0045b6 60%,
            #1a6cff 100%
        );
    }
    .promo-slide--2 {
        background: linear-gradient(
            135deg,
            #0d1b2a 0%,
            #1b4f72 60%,
            #0e86d4 100%
        );
    }
    .promo-slide--3 {
        background: linear-gradient(
            135deg,
            #0a0a1a 0%,
            #2c0057 60%,
            #6e00aa 100%
        );
    }

    .promo-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        color: rgba(255, 255, 255, 0.55);
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        user-select: none;
    }

    /* Dot navigation */
    .promo-dots {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
    }

    .promo-dot {
        width: 8px;
        height: 8px;
        border-radius: 9999px;
        border: none;
        background: var(--color-border);
        cursor: pointer;
        padding: 0;
        transition:
            background 0.2s,
            width 0.3s;
        flex-shrink: 0;
    }
    .promo-dot.active {
        background: var(--color-accent);
        width: 24px;
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
        .hero-content {
            grid-template-columns: 1fr;
            padding: 6rem 1.5rem 4rem;
            gap: 2.5rem;
        }
        .hero-title {
            max-width: 100%;
        }
        .hero-sub {
            max-width: 100%;
        }
        .dither-blob {
            left: 0;
            bottom: 0;
            transform: translate(-50%, 50%);
            width: 90vw;
            height: 90vw;
            opacity: 0.55;
        }
    }
</style>

<script>
    const track = document.getElementById("promoTrack") as HTMLElement | null;
    const dotsContainer = document.getElementById(
        "promoDots",
    ) as HTMLElement | null;
    const wrapper = document.getElementById("heroPromo") as HTMLElement | null;

    if (track && dotsContainer && wrapper) {
        const dots = Array.from(
            dotsContainer.querySelectorAll<HTMLButtonElement>(".promo-dot"),
        );
        const total = dots.length;
        let current = 0;
        let timer: ReturnType<typeof setInterval>;

        function goTo(index: number) {
            current = (index + total) % total;
            track!.style.transform = `translateX(-${current * 100}%)`;
            dots.forEach((d, i) => d.classList.toggle("active", i === current));
        }

        function startTimer() {
            clearInterval(timer);
            timer = setInterval(() => goTo(current + 1), 4000);
        }

        dots.forEach((dot) => {
            dot.addEventListener("click", () => {
                clearInterval(timer);
                goTo(Number(dot.dataset.index));
                startTimer();
            });
        });

        wrapper.addEventListener("mouseenter", () => clearInterval(timer));
        wrapper.addEventListener("mouseleave", startTimer);

        startTimer();
    }
</script>
