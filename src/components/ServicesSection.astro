---
const services = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Cable TV',
    description:
      'Más de 200 canales con deportes premium, películas y programación local — en impactante calidad HD y 4K.',
    features: ['200+ canales', 'Calidad 4K y HD', 'DVR incluido', 'Biblioteca on demand'],
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="var(--color-accent)"/></svg>`,
    title: 'Internet de Alta Velocidad',
    description:
      'Internet por fibra de hasta 10 Gbps con velocidades simétricas — diseñado para streaming, gaming y trabajo remoto.',
    features: ['Hasta 10 Gbps', 'Subida/bajada simétrica', 'Sin límite de datos', 'Módem y router gratis'],
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="var(--color-accent)" stroke="none"/></svg>`,
    title: 'Streaming',
    description:
      'Deportes en vivo, películas y series on demand desde cualquier dispositivo — con calidad 4K y sin cortes.',
    features: ['Deportes en vivo', 'Películas on demand', 'Calidad 4K', 'Multidispositivo'],
  },
];
---

<section id="services" style="padding: 6rem 1.5rem; background: var(--color-bg);">
  <div style="max-width: 1200px; margin: 0 auto;">
    <!-- Section header -->
    <div style="text-align: center; margin-bottom: 3.5rem;">
      <p
        style="font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 0.75rem;"
      >
        Nuestros Servicios
      </p>
      <h2
        style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.025em; color: var(--color-foreground); margin: 0 0 1rem;"
      >
        Todo lo que necesitás, un solo proveedor
      </h2>
      <p style="font-size: 1rem; color: var(--color-muted); max-width: 480px; margin: 0 auto; line-height: 1.6;">
        Soluciones combinadas para simplificar tu vida — una sola factura, un solo llamado, conectividad total.
      </p>
    </div>

    <!-- Cards grid -->
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.25rem;"
    >
      {services.map((service) => (
        <div class="service-card">
          <!-- Icon -->
          <div
            style="width: 44px; height: 44px; border-radius: 10px; background: var(--color-accent-subtle); border: 1px solid var(--color-accent); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; flex-shrink: 0;"
            set:html={service.icon}
          />

          <h3
            style="font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin: 0 0 0.625rem; letter-spacing: -0.01em;"
          >
            {service.title}
          </h3>
          <p style="font-size: 0.9rem; color: var(--color-muted); line-height: 1.65; margin: 0 0 1.25rem;">
            {service.description}
          </p>

          <!-- Feature list -->
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.45rem;">
            {service.features.map((f) => (
              <li style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--color-muted);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: border-color 0.25s, transform 0.2s, box-shadow 0.25s;
  }
  .service-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px var(--color-card-shadow);
  }
</style>
