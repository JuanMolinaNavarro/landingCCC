---

---

<header id="navbar">
    <nav>
        <!-- Logo -->
        <a href="/" class="logo-link">
            <img
                src="/logo.png"
                alt="CCC"
                class="logo-dark"
                style="height: 26px; width: auto;"
            />
            <img
                src="/logoBlue.png"
                alt="CCC"
                class="logo-light"
                style="height: 26px; width: auto;"
            />
        </a>

        <!-- Desktop nav links -->
        <div class="nav-links">
            <a href="#services" class="nav-link">Servicios</a>
            <a href="#plans" class="nav-link">Planes</a>
            <a href="#contact" class="nav-link">Contacto</a>
        </div>

        <!-- Theme Toggle -->
        <button id="theme-toggle" aria-label="Toggle theme" class="theme-btn">
            <svg
                class="sun-icon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><circle cx="12" cy="12" r="5"></circle><path
                    d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
                ></path></svg
            >
            <svg
                class="moon-icon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                ></path></svg
            >
        </button>

        <!-- CTA -->
        <a
            href="https://viaccc.portal.ispboss.com/Login.aspx?ReturnUrl=%2f"
            class="cta-btn">Portal de Abonados</a
        >

        <!-- Mobile menu button -->
        <button
            id="mobile-menu-btn"
            aria-label="Toggle menu"
            class="mobile-btn"
        >
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </nav>
</header>

<!-- Mobile menu (outside pill, below) -->
<div id="mobile-menu" class="mobile-menu">
    <a href="#services" class="mobile-link">Servicios</a>
    <a href="#plans" class="mobile-link">Planes</a>
    <a href="#coverage" class="mobile-link">Cobertura</a>
    <a href="#contact" class="mobile-link">Contacto</a>
    <a
        href="https://viaccc.portal.ispboss.com/Login.aspx?ReturnUrl=%2f"
        class="mobile-cta">Portal de Abonados</a
    >
</div>

<style>
    #navbar {
        position: fixed;
        top: 1.25rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 50;
        width: max-content;
        max-width: calc(100vw - 2rem);
        border-radius: 9999px;

        /* Transparent starting state */
        background: transparent;
        backdrop-filter: blur(0px);
        -webkit-backdrop-filter: blur(0px);
        border: 1px solid transparent;
        box-shadow: none;

        transition:
            background 0.4s ease,
            box-shadow 0.4s ease,
            border-color 0.4s ease,
            backdrop-filter 0.4s ease,
            -webkit-backdrop-filter 0.4s ease;
    }

    #navbar::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 9999px;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.07) 0%,
            rgba(255, 255, 255, 0.01) 50%,
            rgba(255, 255, 255, 0.04) 100%
        );
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.4s ease;
    }

    /* Scrolled pill state */
    #navbar.scrolled {
        background: var(--color-pill-bg);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border-color: var(--color-border-light);
        box-shadow:
            0 4px 24px var(--color-card-shadow),
            0 1px 0 var(--color-border-light) inset,
            0 -1px 0 rgba(0, 0, 0, 0.1) inset;
    }

    #navbar.scrolled::before {
        opacity: 1;
    }

    nav {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem 0.75rem 1.5rem;
        height: 60px;
        transition:
            padding 0.4s ease,
            gap 0.4s ease,
            height 0.4s ease;
    }

    #navbar.scrolled nav {
        gap: 0.25rem;
        padding: 0.5rem 1rem 0.5rem 1.25rem;
        height: 52px;
    }

    .logo-link {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-right: 1.5rem;
        text-decoration: none;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .nav-link {
        color: var(--color-foreground-alt);
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        padding: 0.375rem 0.75rem;
        border-radius: 9999px;
        transition:
            color 0.2s,
            background 0.2s;
    }
    .nav-link:hover {
        color: var(--color-foreground);
        background: var(--color-pill-hover);
    }

    .theme-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-left: 0.5rem;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-foreground-alt);
        padding: 0.375rem;
        border-radius: 9999px;
        transition:
            background 0.2s,
            color 0.2s;
    }
    .theme-btn:hover {
        background: var(--color-pill-hover);
        color: var(--color-foreground);
    }
    .theme-btn .moon-icon {
        display: none;
    }
    :global(html.light) .theme-btn .sun-icon {
        display: none;
    }
    :global(html.light) .theme-btn .moon-icon {
        display: block;
    }

    .cta-btn {
        margin-left: 1rem;
        padding: 0.4375rem 1.125rem;
        background: rgba(29, 78, 216, 0.85);
        color: #fff;
        border-radius: 9999px;
        font-size: 0.8125rem;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
        border: 1px solid rgba(59, 130, 246, 0.5);
        box-shadow:
            0 0 12px rgba(29, 78, 216, 0.4),
            0 1px 0 rgba(255, 255, 255, 0.1) inset;
        transition:
            background 0.2s,
            box-shadow 0.2s;
        flex-shrink: 0;
    }
    .cta-btn:hover {
        background: rgba(29, 78, 216, 1);
        box-shadow:
            0 0 20px rgba(29, 78, 216, 0.6),
            0 1px 0 rgba(255, 255, 255, 0.1) inset;
    }

    .mobile-btn {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-foreground-alt);
        padding: 0.375rem;
        border-radius: 9999px;
        transition:
            background 0.2s,
            color 0.2s;
    }
    .mobile-btn:hover {
        background: var(--color-pill-hover);
        color: var(--color-foreground);
    }

    /* Mobile menu */
    .mobile-menu {
        display: none;
        position: fixed;
        top: 5.25rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 49;
        width: calc(100vw - 2rem);
        max-width: 420px;

        background: var(--color-surface);
        backdrop-filter: blur(20px) saturate(160%);
        -webkit-backdrop-filter: blur(20px) saturate(160%);
        border-radius: 1.25rem;
        border: 1px solid var(--color-border);
        box-shadow: 0 8px 32px var(--color-card-shadow);
        padding: 0.75rem;
        flex-direction: column;
        gap: 0.25rem;
    }
    .mobile-menu.open {
        display: flex;
    }

    .mobile-link {
        display: block;
        padding: 0.7rem 1rem;
        color: var(--color-foreground-alt);
        font-size: 0.9375rem;
        font-weight: 500;
        text-decoration: none;
        border-radius: 0.75rem;
        transition:
            color 0.2s,
            background 0.2s;
    }
    .mobile-link:hover {
        color: var(--color-foreground);
        background: var(--color-surface2);
    }

    .mobile-cta {
        display: block;
        margin-top: 0.25rem;
        padding: 0.7rem 1rem;
        background: rgba(29, 78, 216, 0.85);
        color: #fff;
        border-radius: 0.75rem;
        font-size: 0.9375rem;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        border: 1px solid rgba(59, 130, 246, 0.4);
        box-shadow: 0 0 12px rgba(29, 78, 216, 0.3);
        transition: background 0.2s;
    }
    .mobile-cta:hover {
        background: rgba(29, 78, 216, 1);
    }

    @media (max-width: 640px) {
        .nav-links,
        .cta-btn {
            display: none !important;
        }
        .mobile-btn {
            display: flex !important;
        }
    }
</style>

<script>
    const setupNav = () => {
        const navbar = document.getElementById("navbar");
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        const themeBtn = document.getElementById("theme-toggle");

        // Toggle scroll state
        const handleScroll = () => {
            if (window.scrollY > 20) {
                navbar?.classList.add("scrolled");
            } else {
                navbar?.classList.remove("scrolled");
            }
        };

        // Run on mount to check initial position
        handleScroll();
        window.addEventListener("scroll", handleScroll, { passive: true });

        // Mobile menu handlers
        btn?.addEventListener("click", () => {
            menu?.classList.toggle("open");
        });

        menu?.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
                menu?.classList.remove("open");
            });
        });

        // Theme toggle
        const toggleTheme = () => {
            const html = document.documentElement;
            if (html.classList.contains("light")) {
                html.classList.remove("light");
                localStorage.setItem("theme", "dark");
            } else {
                html.classList.add("light");
                localStorage.setItem("theme", "light");
            }
        };

        themeBtn?.addEventListener("click", toggleTheme);
    };

    setupNav();
    document.addEventListener("astro:page-load", setupNav);
</script>
